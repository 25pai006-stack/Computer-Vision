import cv2
from skimage.feature import graycomatrix, graycoprops
img = cv2.imread("/content/sample_data/Brick wall.jpg",0)
glcm = graycomatrix(img,[1],[0],256,symmetric=True,normed=True)
contrast = graycoprops(glcm,'contrast')
correlation = graycoprops(glcm,'correlation')
energy = graycoprops(glcm,'energy')
homogeneity = graycoprops(glcm,'homogeneity')
print("Contrast:",contrast)
print("Correlation:",correlation)
print("Energy:",energy)
print("Homogeneity:",homogeneity)
import cv2
import numpy as np
from sklearn import svm
img = cv2.imread("/content/sample_data/Cell Tumor Microscopy.jpg",0)
_,th = cv2.threshold(img,127,255,cv2.THRESH_BINARY)
contours,_ = cv2.findContours(th,cv2.RETR_TREE,cv2.CHAIN_APPROX_SIMPLE)
 = contours[0]
area = cv2.contourArea(cnt)
perimeter = cv2.arcLength(cnt,True)
circularity = 4*np.pi*(area/(perimeter*perimeter))
X = [[area,perimeter,circularity]]
y = [1]
X.append([100.0, 40.0, 0.7]) # Example features for another hypothetical object
y.append(0) # Assign a different class label (e.g., 'non-tumor')
model = svm.SVC()
model.fit(X,y)
prediction = model.predict([[area,perimeter,circularity]])
print("Classification:",prediction)
